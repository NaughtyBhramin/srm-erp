# ════════════════════════════════════════════════════════
#  SRM ERP — .gitignore
#  Covers: Python, Java/Maven, Node.js, Docker, IDE, OS
# ════════════════════════════════════════════════════════


# ──────────────────────────────────────
#  SECRETS & ENVIRONMENT (NEVER COMMIT)
# ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.jks
secrets/
credentials/


# ──────────────────────────────────────
#  PYTHON — BACKEND (FastAPI)
# ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.pyc
*.pyo

# Virtual environments
venv/
.venv/
ENV/
env/
env.bak/
venv.bak/
.python-version

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.coveragerc
nosetests.xml
test-results/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Linting
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Distribution
MANIFEST
pip-log.txt
pip-delete-this-directory.txt


# ──────────────────────────────────────
#  JAVA — MICROSERVICE (Spring Boot)
# ──────────────────────────────────────
target/
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Gradle (if used)
.gradle/
gradle-app.setting
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# STS / Spring Tool Suite
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/


# ──────────────────────────────────────
#  NODE.JS — FRONTEND (React + Vite)
# ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Vite build output
dist/
dist-ssr/

# Vite cache
.vite/

# Next.js (if migrated)
.next/
out/

# Nuxt.js (if used)
.nuxt/

# Storybook
storybook-static/

# Testing
coverage/
.nyc_output/

# Package lock files — keep one, ignore others
# Uncomment whichever you're NOT using:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml


# ──────────────────────────────────────
#  DATABASE
# ──────────────────────────────────────
*.sql.bak
*.dump
*.db
*.sqlite
*.sqlite3
db_backups/
pgdata/


# ──────────────────────────────────────
#  DOCKER
# ──────────────────────────────────────
.dockerignore
docker-compose.override.yml
docker-compose.local.yml

# Docker volumes data
postgres_data/
redis_data/
kafka_data/


# ──────────────────────────────────────
#  LOGS & RUNTIME
# ──────────────────────────────────────
*.log
*.log.*
logs/
log/
*.pid
*.seed
*.pid.lock
runtime/
tmp/
temp/


# ──────────────────────────────────────
#  IDE — VS CODE
# ──────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace


# ──────────────────────────────────────
#  IDE — JETBRAINS (IntelliJ, PyCharm)
# ──────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/


# ──────────────────────────────────────
#  IDE — ECLIPSE
# ──────────────────────────────────────
.classpath
.project
.settings/
*.launch
*.prefs


# ──────────────────────────────────────
#  IDE — NETBEANS
# ──────────────────────────────────────
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/


# ──────────────────────────────────────
#  OS — macOS
# ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
.DocumentRevisions-V100
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk


# ──────────────────────────────────────
#  OS — WINDOWS
# ──────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk


# ──────────────────────────────────────
#  OS — LINUX
# ──────────────────────────────────────
*~
.directory
.Trash-*
.nfs*


# ──────────────────────────────────────
#  UPLOADS & MEDIA (local dev only)
# ──────────────────────────────────────
uploads/
media/
static/uploads/
public/uploads/
!public/placeholder.png


# ──────────────────────────────────────
#  TESTING & REPORTS
# ──────────────────────────────────────
test-results/
test-reports/
allure-results/
allure-report/
playwright-report/
playwright/.cache/


# ──────────────────────────────────────
#  MISC
# ──────────────────────────────────────
*.bak
*.backup
*.orig
*.swp
*.swo
.cache/
.parcel-cache/
.turbo/


# ════════════════════════════════════════════════════════
#  KEEP THESE (force-include with !)
# ════════════════════════════════════════════════════════
!.gitkeep
!.env.example
!.mvn/wrapper/maven-wrapper.properties
!**/src/main/**/bin/
